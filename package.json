{
  "name": "@cfmleditor/tree-sitter-cfml",
  "version": "0.26.10",
  "description": "CFML grammar for tree-sitter",
  "repository": "github:cfmleditor/tree-sitter-cfml",
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "author": {
    "name": "garetheddies"
  },
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "cfml"
  ],
  "files": [
    "binding.gyp",
    "scripts/**",
    "prebuilds/**",
    "bindings/node/*",
    "cfml/grammar.js",
    "cfml/queries/*",
    "cfml/src/**",
    "cfhtml/grammar.js",
    "cfhtml/queries/*",
    "cfhtml/src/**",
    "cfscript/grammar.js",
    "cfscript/queries/*",
    "cfscript/src/**",
    "cfquery/grammar.js",
    "cfquery/queries/*",
    "cfquery/src/**",
    "common/define-grammar.js"
  ],
  "dependencies": {
    "node-addon-api": "^8.7.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-treesitter": "^1.0.2",
    "globals": "^17.6.0",
    "prebuildify": "^6.0.1",
    "tree-sitter": "0.25.0",
    "tree-sitter-cli": "0.26.8"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18 <=24"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "parse": "node scripts/parse.js",
    "test": "node scripts/test.js",
    "docswasm": "node scripts/docswasm.js",
    "install": "node-gyp-build",
    "postinstall": "node scripts/ensure-tree-sitter-cli-binary.js",
    "prestart": "node scripts/prestart-wasm.js",
    "start": "node scripts/start-playground.js",
    "playground": "node scripts/playground.js",
    "testbindings": "node --test bindings/node/*_test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "publishConfig": {
    "access": "public"
  }
}
