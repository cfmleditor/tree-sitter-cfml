{
  "$schema": "https://example.com/schemas/cfml-vendor-support.schema.json",
  "description": "Vendor/version support metadata for CFML constructs. This file is intended to be consumed by tooling that wants to filter the grammar/features by engine (ACF vs Lucee) and version.",
  "version": 1,
  "documentation_sources": {
    "ACF": {
      "name": "Adobe ColdFusion",
      "url": "https://helpx.adobe.com/support/coldfusion.html",
      "notes": "Adobe ColdFusion CFML Reference (tags, functions) under helpx.adobe.com/coldfusion/cfml-reference/."
    },
    "Lucee": {
      "name": "Lucee CFML",
      "url": "http://localhost:4040",
      "url_public": "https://docs.lucee.org",
      "notes": "Local Lucee docs at localhost:4040; public reference at docs.lucee.org. Tag reference URLs use the tag name without the cf prefix in the path (e.g. /reference/tags/query.html for cfquery)."
    }
  },
  "constructs": [
    {
      "kind": "tag",
      "name": "cfquery",
      "notes": "Passes SQL to a data source; Adobe recommends cfqueryparam for security. ACF: attribute history (e.g. returnType 2021, disableAutoGenKeys 2018); deprecated sql/provider/dbServer/dbName/connectString removed in CF11.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-tags/tags-p-q/cfquery.html",
        "Lucee": "https://docs.lucee.org/reference/tags/query.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "tag",
      "name": "cfscript",
      "notes": "CFScript block tag. Embeds script syntax in tag-based pages. Documented in both Adobe ColdFusion and Lucee CFML references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-tags/tags-c-d/cfscript.html",
        "Lucee": "https://docs.lucee.org/reference/tags/script.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "tag",
      "name": "cfxml",
      "notes": "XML processing tag. Creates XML document object from literal or variable. Documented in Adobe CFML Reference and Lucee.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-tags/tags-u-z/cfxml.html",
        "Lucee": "https://docs.lucee.org/reference/tags/xml.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "tag",
      "name": "cftransaction",
      "notes": "Groups database operations as a single transaction; supports action (begin/commit/rollback/setsavepoint), isolation, savepoint, nested. Documented in both Adobe and Lucee.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-tags/tags-t/cftransaction.html",
        "Lucee": "https://docs.lucee.org/reference/tags/transaction.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "function",
      "name": "QueryExecute",
      "notes": "Executes SQL with optional params and options; script alternative to cfquery. Adobe CFML Reference and Lucee function reference.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-functions/functions-m-r/queryexecute.html",
        "Lucee": "https://docs.lucee.org/reference/functions/queryexecute.html"
      },
      "vendors": {
        "ACF": {
          "since": "11",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "NOT",
      "notes": "Logical NOT (keyword form). Equivalent to ! in both Adobe and Lucee; documented in expression/operator references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "XOR",
      "notes": "Logical exclusive OR (keyword form). Documented in Adobe expressions and Lucee operators.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "MOD",
      "notes": "Modulo (remainder) operator; keyword form. Equivalent to % in Adobe and Lucee; documented in operator references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "CT",
      "notes": "Shorthand for CONTAINS. Documented in Lucee operators; available in ACF expression language.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "NCT",
      "notes": "Shorthand for DOES NOT CONTAIN. Documented in Lucee operators; available in ACF expression language.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "<>",
      "notes": "Not-equal comparison operator. Documented in both Adobe and Lucee operator/expression references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "\\\\",
      "notes": "Integer division operator. Documented in Lucee; also available in ACF expression language.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-expressions-and-number-signs/expressions-developing-guide.ug.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "operator",
      "name": "?:",
      "notes": "Elvis operator. ACF (CF2016+): shorthand ternary; Lucee: null-coalescing (default when left side is null/undefined). Semantics differ between engines.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/cfml-reference/coldfusion-script-functions/elvis-operator.html",
        "Lucee": "https://docs.lucee.org/guides/developing-with-lucee-server/operators.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "scope",
      "name": "variables",
      "notes": "VARIABLES scope for component/page variables. Documented in Adobe and Lucee scope references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-cfml-elements/using-data-types.html",
        "Lucee": "https://docs.lucee.org/reference/scopes/variables.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "scope",
      "name": "arguments",
      "notes": "ARGUMENTS scope for function parameters. Documented in Adobe and Lucee scope references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-cfml-elements/using-data-types.html",
        "Lucee": "https://docs.lucee.org/reference/scopes/arguments.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "scope",
      "name": "session",
      "notes": "SESSION scope for session-level data. Documented in Adobe and Lucee scope references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-cfml-elements/using-data-types.html",
        "Lucee": "https://docs.lucee.org/reference/scopes/session.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    },
    {
      "kind": "scope",
      "name": "application",
      "notes": "APPLICATION scope for application-level data. Documented in Adobe and Lucee scope references.",
      "documentation": {
        "ACF": "https://helpx.adobe.com/coldfusion/developing-applications/the-cfml-programming-language/using-cfml-elements/using-data-types.html",
        "Lucee": "https://docs.lucee.org/reference/scopes/application.html"
      },
      "vendors": {
        "ACF": {
          "since": "",
          "deprecated_since": null
        },
        "Lucee": {
          "since": "",
          "deprecated_since": null
        }
      }
    }
  ]
}

