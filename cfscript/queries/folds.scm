; Fold function bodies
(function_declaration) @fold
(function_expression) @fold
(arrow_function) @fold

; Fold control flow
(if_statement) @fold
(for_statement) @fold
(for_in_statement) @fold
(while_statement) @fold
(do_statement) @fold
(switch_statement) @fold
(try_statement) @fold

; Fold blocks
(statement_block) @fold
(component_body) @fold
(component) @fold

; Fold comments
(comment) @fold
